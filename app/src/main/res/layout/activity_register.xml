<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#181818"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOP LIME STRIPE -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#AAFF00" />

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="44dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <View
                    android:layout_width="20dp"
                    android:layout_height="2dp"
                    android:background="#AAFF00"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CREATE ACCOUNT"
                    android:textColor="#AAFF00"
                    android:fontFamily="@font/font_oswald_bold"
                    android:textSize="10sp"
                    android:letterSpacing="0.28" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtRegestration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REGIS"
                    android:textColor="#F0F0F0"
                    android:textSize="52sp"
                    android:fontFamily="@font/font_oswald_bold"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TER"
                    android:textColor="#AAFF00"
                    android:textSize="52sp"
                    android:fontFamily="@font/font_oswald_bold"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="8dp">

                <View
                    android:layout_width="36dp"
                    android:layout_height="3dp"
                    android:background="#AAFF00"
                    android:layout_marginEnd="10dp" />

                <View
                    android:layout_width="10dp"
                    android:layout_height="3dp"
                    android:background="#AAFF00" />
            </LinearLayout>

        </LinearLayout>

        <!-- FORM FIELDS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_person"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FULL NAME"
                    android:textColor="#AAFF00"
                    android:fontFamily="@font/font_oswald_bold"
                    android:textSize="10sp"
                    android:letterSpacing="0.22" />
            </LinearLayout>

            <EditText
                android:id="@+id/edtFullNameReg"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="John Doe"
                android:inputType="textPersonName"
                android:textColor="#F0F0F0"
                android:textColorHint="#555555"
                android:textSize="15sp"
                android:background="@null"
                android:backgroundTint="#AAFF00"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_email"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMAIL"
                    android:textColor="#AAFF00"
                    android:fontFamily="@font/font_oswald_bold"
                    android:textSize="10sp"
                    android:letterSpacing="0.22" />
            </LinearLayout>

            <EditText
                android:id="@+id/edtEmailAdressReg"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="your@email.com"
                android:inputType="textEmailAddress"
                android:textColor="#F0F0F0"
                android:textColorHint="#555555"
                android:textSize="15sp"
                android:background="@null"
                android:backgroundTint="#AAFF00"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_password"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASSWORD"
                    android:textColor="#AAFF00"
                    android:fontFamily="@font/font_oswald_bold"
                    android:textSize="10sp"
                    android:letterSpacing="0.22" />
            </LinearLayout>

            <EditText
                android:id="@+id/edtPasswordReg"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:textColor="#F0F0F0"
                android:textColorHint="#555555"
                android:textSize="15sp"
                android:background="@null"
                android:backgroundTint="#AAFF00"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_password"
                    android:layout_marginEnd="6dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REPEAT PASSWORD"
                    android:textColor="#AAFF00"
                    android:fontFamily="@font/font_oswald_bold"
                    android:textSize="10sp"
                    android:letterSpacing="0.22" />
            </LinearLayout>

            <EditText
                android:id="@+id/edtRepeatPasswordReg"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:textColor="#F0F0F0"
                android:textColorHint="#555555"
                android:textSize="15sp"
                android:background="@null"
                android:backgroundTint="#AAFF00"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:paddingBottom="8dp" />

        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="36dp" />

        <!-- BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingBottom="40dp">

            <Button
                android:id="@+id/btnRegisterReg"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="REGISTER  →"
                android:textColor="#111111"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.18"
                android:fontFamily="@font/font_oswald_bold"
                android:backgroundTint="#AAFF00"
                android:layout_marginBottom="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#2E2E2E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  OR  "
                    android:textColor="#555555"
                    android:textSize="10sp"
                    android:fontFamily="@font/font_oswald_bold"
                    android:letterSpacing="0.18" />

                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#2E2E2E" />
            </LinearLayout>

            <Button
                android:id="@+id/btnLoginReg"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="LOGIN"
                android:textColor="#AAFF00"
                android:fontFamily="@font/font_oswald_bold"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.18"
                android:backgroundTint="#202020"
                android:strokeColor="#2E2E2E"
                />

        </LinearLayout>

    </LinearLayout>
</ScrollView>